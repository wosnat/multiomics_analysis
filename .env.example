# KG credentials for the multiomics explorer / MCP server.
# Copy this file to `.env` (same directory, the repo root) and fill in the
# operator-provided values. `.env` is gitignored — NEVER commit real credentials.
#
# The MCP server runs from the repo root, so the explorer reads this file
# automatically. See the README "Set KG credentials" section.

NEO4J_URI=bolt://HOST:PORT
NEO4J_USERNAME=explorer
NEO4J_PASSWORD=

# Optional — defaults to "neo4j" if unset.
# NEO4J_DATABASE=neo4j
