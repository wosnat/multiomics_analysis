{"timestamp":"2026-06-13T19:34:54Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"0c83bd31-108e-49cd-9647-f4e0a89be934","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (g:Gene)-[:Gene_belongs_to_organism]->(o:OrganismTaxon)\nWHERE o.genus = 'Prochlorococcus'\nOPTIONAL MATCH (g)-[:Gene_has_cyanorak_role]->(r:CyanorakRole {id:'cyanorak.role:D.1.5'})\nWITH o, count(DISTINCT g) AS total_genes,\n     count(DISTINCT CASE WHEN r IS NOT NULL THEN g END) AS p_role_genes\nRETURN o.organism_name AS organism, o.clade AS clade, o.experiment_count AS exp, total_genes, p_role_genes\nORDER BY clade, organism","limit":30},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":19,"error":null}
{"timestamp":"2026-06-13T19:35:26Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"0c83bd31-108e-49cd-9647-f4e0a89be934","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (g:Gene)-[:Gene_belongs_to_organism]->(o:OrganismTaxon)\nWHERE o.genus = 'Prochlorococcus'\nOPTIONAL MATCH (g)-[:Gene_has_cyanorak_role]->(r:CyanorakRole)\nOPTIONAL MATCH (g)-[:Gene_in_ortholog_group]->(og:OrthologGroup {source:'cyanorak'})\nWITH o, count(DISTINCT g) AS total_genes,\n     count(DISTINCT CASE WHEN r IS NOT NULL THEN g END) AS genes_with_any_cyanorak_role,\n     count(DISTINCT CASE WHEN og IS NOT NULL THEN g END) AS genes_in_cyanorak_og\nRETURN o.organism_name AS organism, o.clade AS clade, o.experiment_count AS exp,\n       total_genes, genes_with_any_cyanorak_role, genes_in_cyanorak_og\nORDER BY genes_with_any_cyanorak_role, organism","limit":30},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":19,"error":null}
