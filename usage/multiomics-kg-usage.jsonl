{"timestamp":"2026-06-13T19:34:29Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"0c83bd31-108e-49cd-9647-f4e0a89be934","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (o:Organism) WHERE o.preferred_name IN ['Prochlorococcus MED4','Prochlorococcus MIT9515','Prochlorococcus SB','Prochlorococcus MIT1327','Prochlorococcus MIT9313','Prochlorococcus PAC1']\nOPTIONAL MATCH (o)<-[:Belongs_to_organism|In_organism|Encoded_by*1..2]-(g:Gene)\nWITH o, count(DISTINCT g) AS genes\nRETURN o.preferred_name AS organism, o.experiment_count AS exp_count, genes\nORDER BY organism"},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":0,"error":null}
