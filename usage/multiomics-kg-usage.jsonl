{"timestamp":"2026-06-15T11:12:22Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"d936c7a6-c5c8-4711-a06e-2f3293602467","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (e:Experiment)\nWHERE e.organism_name CONTAINS 'Alteromonas'\n  AND (e.coculture_partner CONTAINS 'Prochlorococcus'\n       OR e.id CONTAINS '690089' OR e.id CONTAINS 'ismeco' OR e.id CONTAINS 'mSystems')\nRETURN e.id AS exp, e.omics_type AS omics, e.treatment AS treatment,\n       e.control AS control, e.growth_phases AS growth_phases,\n       e.time_point_labels AS tp_labels, e.time_point_hours AS tp_hours,\n       e.time_point_growth_phases AS tp_phases\nORDER BY exp","limit":30},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":21,"error":null}
{"timestamp":"2026-06-15T17:31:58Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"d936c7a6-c5c8-4711-a06e-2f3293602467","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (k:KeggTerm)\nWHERE k.id IN ['kegg.pathway:ko02040','kegg.pathway:ko02030','ko02040','ko02030']\n   OR k.name CONTAINS 'lagellar' OR k.name CONTAINS 'hemotaxis'\nRETURN k.id AS id, k.name AS name, k.level AS level, k.level_kind AS level_kind\nORDER BY level\nLIMIT 25"},"response_keys":["results","returned","truncated","warnings"],"truncated":true,"total_matching":null,"returned":25,"error":null}
