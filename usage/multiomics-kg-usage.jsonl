{"timestamp":"2026-06-15T10:37:52Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"d936c7a6-c5c8-4711-a06e-2f3293602467","tool_name":"mcp__multiomics-kg__kg_schema","tool_input":{},"response_keys":["nodes","relationships"],"truncated":null,"total_matching":null,"returned":null,"error":null}
{"timestamp":"2026-06-15T10:38:05Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"d936c7a6-c5c8-4711-a06e-2f3293602467","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (e:Experiment)-[r:Changes_expression_of]->(g:Gene)\nWHERE e.id IN ['10.1038/ismej.2016.70_coculture_prochlorococcus_mit9313_hot1a3_rnaseq','10.1038/ismej.2016.82_coculture_24_hours_after_coculturing_mit1002_rnaseq']\nRETURN e.id AS exp,\n       r.significant AS significant,\n       r.expression_direction AS direction,\n       r.expression_status AS status,\n       CASE WHEN r.log2_fold_change IS NULL THEN 'null'\n            WHEN r.log2_fold_change > 0 THEN 'pos'\n            WHEN r.log2_fold_change < 0 THEN 'neg'\n            ELSE 'zero' END AS l2fc_sign,\n       count(*) AS n\nORDER BY exp, significant, direction, l2fc_sign","limit":100},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":4,"error":null}
{"timestamp":"2026-06-15T10:38:34Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"d936c7a6-c5c8-4711-a06e-2f3293602467","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (o:OrganismTaxon)<-[:Gene_belongs_to_organism]-(g:Gene)<-[r:Changes_expression_of]-(e:Experiment)\nWHERE o.organism_name CONTAINS 'Alteromonas'\nWITH e.id AS exp, e.omics_type AS omics, e.table_scope AS scope,\n     sum(CASE WHEN r.log2_fold_change < 0 THEN 1 ELSE 0 END) AS neg,\n     sum(CASE WHEN r.log2_fold_change > 0 THEN 1 ELSE 0 END) AS pos,\n     sum(CASE WHEN r.log2_fold_change IS NULL THEN 1 ELSE 0 END) AS nullfc,\n     count(*) AS total\nRETURN exp, omics, scope, neg, pos, nullfc, total,\n       toInteger(100.0*neg/total) AS pct_neg\nORDER BY pct_neg, exp","limit":100},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":0,"error":null}
{"timestamp":"2026-06-15T10:38:44Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"d936c7a6-c5c8-4711-a06e-2f3293602467","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (e:Experiment)-[r:Changes_expression_of]->(g:Gene)\nWHERE e.organism_name CONTAINS 'Alteromonas'\nWITH e.id AS exp, e.omics_type AS omics, e.table_scope AS scope,\n     e.significant_up_count AS rollup_up, e.significant_down_count AS rollup_down,\n     sum(CASE WHEN r.log2_fold_change < 0 THEN 1 ELSE 0 END) AS neg,\n     sum(CASE WHEN r.log2_fold_change > 0 THEN 1 ELSE 0 END) AS pos,\n     count(*) AS total\nRETURN exp, omics, scope, rollup_up, rollup_down, neg, pos, total,\n       toInteger(100.0*neg/total) AS pct_neg\nORDER BY pct_neg, exp","limit":100},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":41,"error":null}
{"timestamp":"2026-06-15T10:41:57Z","template_version":"0.1.0-alpha.1","event":"PostToolUse","session_id":"d936c7a6-c5c8-4711-a06e-2f3293602467","tool_name":"mcp__multiomics-kg__run_cypher","tool_input":{"query":"MATCH (e:Experiment)\nWHERE e.id IN [\n  '10.1038/ismej.2016.70_coculture_prochlorococcus_mit9313_high_alteromonas_hot1a3_rnaseq',\n  '10.1038/ismej.2016.70_coculture_prochlorococcus_mit9313_hot1a3_rnaseq',\n  '10.1038/ismej.2016.82_coculture_24_hours_after_coculturing_mit1002_rnaseq',\n  '10.1038/ismej.2016.82_coculture_48_hours_after_coculturing_mit1002_rnaseq',\n  '10.1101/2025.11.24.690089_coculture_prochlorococcus_med4_hot1a3_rnaseq'\n]\nRETURN e.id AS exp, e.table_scope AS scope, e.reports_fold_change AS reports_fc,\n       e.statistical_test AS stat_test, e.table_scope_detail AS detail","limit":10},"response_keys":["results","returned","truncated","warnings"],"truncated":null,"total_matching":null,"returned":5,"error":null}
